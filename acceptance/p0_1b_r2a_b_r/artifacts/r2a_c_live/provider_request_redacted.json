  "EVIDENCE_ANCHOR_PROTOCOL": {
    "protocol_version": "xcue.l1-rebuild-evidence-anchor/1.0",
    "paragraph_source_of_truth": "semantic_group_request.chapter_payload.paragraphs",
    "paragraph_source_path": "$.semantic_group_request.chapter_payload.paragraphs",
    "raw_text_source_path": "$.semantic_group_request.chapter_payload.raw_text",
    "paragraph_count": 63,
    "same_paragraph_required": true,
    "same_paragraph_requirement": true,
    "verbatim_contiguous_text_required": true,
    "occurrence_index_base": 0,
    "text_normalization_allowed": false,
    "cross_paragraph_stitching_allowed": false,
    "selection_order": [
      "1. 先从 semantic_group_request.chapter_payload.paragraphs 选择一个真实 paragraph 对象；",
      "2. paragraph_id 必须原样复制该 paragraph.paragraph_id，不得估计或重编号；",
      "3. exact_text 必须从该 paragraph.text 中原样复制一段连续子串；",
      "4. 不得改写、概括、补字、删字或规范化标点/引号/空格；",
      "5. occurrence_index 按 exact_text 在该 paragraph.text 中的零基出现次序计算；",
      "6. source_id 必须等于 evidence_anchor_context.expected_source_id；",
      "7. 输出前逐项自检 paragraph_id、exact_text、occurrence_index、source_id 是否一致。"
    ],
    "exact_text_rules": {
      "must_be_contiguous_substring": "exact_text 必须是指定 paragraph.text 中的同段连续原文子串；不得来自 raw_text 的其他位置或其他 paragraph。",
      "forbidden_normalizations": [
        "跨段拼接多段 paragraph.text",
        "用省略号替代中间内容",
        "半角标点改全角或全角改半角",
        "直引号改弯引号或弯引号改直引号",
        "增删空格或 strip 后再匹配",
        "补字、删字或增加“的、了、是”等字或删除语气词",
        "概括复述或根据记忆改写原文",
        "简繁转换或模糊匹配"
      ],
      "forbidden_cross_paragraph_stitching": true
    },
    "paragraph_id_rules": {
      "must_copy_from_chapter_payload": true,
      "paragraph_source_path": "$.semantic_group_request.chapter_payload.paragraphs",
      "definition": "paragraph_id 不是语义位置估计；只能从 paragraph_source_path 指向的 paragraphs 中复制真实 paragraph_id。",
      "forbidden": [
        "因句子在 raw_text 中存在而填写另一 paragraph_id",
        "重新编号或臆造 paragraph_id"
      ]
    },
    "occurrence_index_rules": {
      "zero_based": true,
      "scope": "within_assigned_paragraph_text_only",
      "definition": "occurrence_index 为零基索引，只统计 exact_text 在指定 paragraph.text 中的出现次数；不统计全文或其他段落。第一次出现 → 0，第二次出现 → 1。"
    },
    "source_id_rules": {
      "expected_source_id": "ch01",
      "must_equal_expected_source_id": true,
      "definition": "所有 PARAGRAPH_ANCHOR.source_id 必须等于 expected_source_id；不得自行猜测 ch01/chapter-1/current_chapter 等值。"
    },
    "forbidden_cross_paragraph_stitching": true,
    "when_no_valid_anchor": {
      "must_not_fabricate": true,
      "must_not_use_approximate_quote": true,
      "must_not_assign_foreign_paragraph_text": true,
      "guidance": "找不到合法 PARAGRAPH_ANCHOR 时不得伪造证据、不得用近似句替代原文、不得输出不属于指定段落的 exact_text。若 FAIL/REVIEW 需要证据但无合法锚点，须依据 R1 该 criterion 的输入与证据合同重新判断 decision；不得为维持原 decision 制造假证据。"
    },
    "self_check_before_output": [
      "paragraph_id 是否存在于 paragraph_source_path 指向的 paragraphs",
      "exact_text 是否为该 paragraph.text 的连续子串",
      "occurrence_index 是否与该 paragraph.text 内第 N 次出现一致",
      "source_id 是否等于 expected_source_id"
    ]
  },
  "evidence_anchor_context": {
    "expected_source_id": "ch01",
    "paragraph_source_path": "$.semantic_group_request.chapter_payload.paragraphs"
  },
