{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xcue.schema/audit-blockers/1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pipeline_run_id",
    "stage_run_id",
    "status",
    "semantic_audit_status",
    "audit_reason_type",
    "blocker_count",
    "items"
  ],
  "properties": {
    "schema_version": {
      "const": "xcue.audit-blockers/1.0"
    },
    "pipeline_run_id": {
      "$ref": "#/$defs/run_id"
    },
    "stage_run_id": {
      "$ref": "#/$defs/run_id"
    },
    "status": {
      "type": "string",
      "enum": [
        "AUDIT_BLOCKED",
        "SCREENING_REJECT",
        "SCREENING_PASS",
        "REVIEW_REQUIRED"
      ]
    },
    "semantic_audit_status": {
      "type": "string",
      "enum": [
        "AUDIT_BLOCKED",
        "PASS",
        "FAIL",
        "REVIEW",
        "UNAVAILABLE",
        "INVALID"
      ]
    },
    "audit_reason_type": {
      "type": "string",
      "enum": [
        "",
        "INPUT_INVALID",
        "API_UNAVAILABLE",
        "EVIDENCE_INVALID",
        "SCHEMA_INVALID"
      ]
    },
    "blocker_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000
    },
    "items": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "$ref": "#/$defs/audit_blocker_item"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true,
      "maxProperties": 50
    }
  },
  "$defs": {
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[0-9A-Za-z_\\-\\u4e00-\\u9fff]+$"
    },
    "text": {
      "type": "string",
      "maxLength": 2000
    },
    "short_text": {
      "type": "string",
      "maxLength": 256
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "段落",
        "摘句"
      ],
      "properties": {
        "段落": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 100000
        },
        "摘句": {
          "$ref": "#/$defs/text"
        },
        "段落ID": {
          "$ref": "#/$defs/short_text"
        },
        "source_scope": {
          "type": "string",
          "enum": [
            "CURRENT_CHAPTER",
            "PRIOR_CHAPTER"
          ]
        },
        "start_offset": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 1000000
        },
        "end_offset": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 1000000
        },
        "occurrence_index": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        }
      }
    },
    "audit_blocker_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "闸门",
        "名称",
        "状态",
        "说明",
        "证据",
        "严重级别",
        "失败类型",
        "候选模块",
        "回流验收位置",
        "修复方向",
        "decision_role",
        "blocking",
        "reason_type"
      ],
      "properties": {
        "闸门": {
          "$ref": "#/$defs/short_text"
        },
        "名称": {
          "$ref": "#/$defs/short_text"
        },
        "状态": {
          "type": "string",
          "enum": [
            "成立",
            "通过",
            "失败",
            "风险",
            "阻断",
            "检测到接口信号",
            "检测到代理信号"
          ]
        },
        "说明": {
          "$ref": "#/$defs/text"
        },
        "证据": {
          "type": "array",
          "maxItems": 200,
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "严重级别": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "失败类型": {
          "$ref": "#/$defs/short_text"
        },
        "候选模块": {
          "$ref": "#/$defs/short_text"
        },
        "回流验收位置": {
          "$ref": "#/$defs/short_text"
        },
        "修复方向": {
          "$ref": "#/$defs/text"
        },
        "heuristic": {
          "type": "boolean"
        },
        "signal_strength": {
          "$ref": "#/$defs/short_text"
        },
        "confidence": {
          "$ref": "#/$defs/short_text"
        },
        "decision_role": {
          "const": "AUDIT_BLOCKER"
        },
        "blocking": {
          "const": true
        },
        "reason_type": {
          "type": "string",
          "enum": [
            "INPUT_INVALID",
            "API_UNAVAILABLE",
            "EVIDENCE_INVALID",
            "SCHEMA_INVALID"
          ]
        }
      }
    }
  }
}
