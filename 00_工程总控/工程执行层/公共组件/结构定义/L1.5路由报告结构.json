{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xcue.schema/l15-route-report/1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "pipeline_run_id",
    "stage_run_id",
    "source_failure_packet",
    "primary_failure",
    "secondary_failures",
    "target_module",
    "repair_product",
    "return_gate",
    "route_rule_id",
    "route_rule_version",
    "final_status",
    "blockers"
  ],
  "properties": {
    "schema_version": {
      "const": "xcue.l15-route-report/1.0"
    },
    "run_id": {
      "$ref": "#/$defs/run_id"
    },
    "pipeline_run_id": {
      "$ref": "#/$defs/run_id"
    },
    "stage_run_id": {
      "$ref": "#/$defs/run_id"
    },
    "source_failure_packet": {
      "$ref": "#/$defs/path_text"
    },
    "primary_failure": {
      "$ref": "#/$defs/failure_snapshot"
    },
    "secondary_failures": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "$ref": "#/$defs/failure_snapshot"
      }
    },
    "target_module": {
      "type": "string",
      "maxLength": 32
    },
    "repair_product": {
      "type": "string",
      "maxLength": 256
    },
    "return_gate": {
      "type": "string",
      "maxLength": 32
    },
    "route_rule_id": {
      "type": "string",
      "maxLength": 64
    },
    "route_rule_version": {
      "type": "string",
      "maxLength": 64
    },
    "final_status": {
      "type": "string",
      "enum": [
        "ROUTED",
        "INPUT_REQUIRED",
        "MANUAL_REVIEW",
        "RETURN_TO_L1",
        "BLOCKED"
      ]
    },
    "blockers": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "$ref": "#/$defs/text"
      }
    },
    "routing_basis": {
      "$ref": "#/$defs/text"
    },
    "extensions": {
      "$ref": "#/$defs/extensions"
    }
  },
  "$defs": {
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[0-9A-Za-z_\\-\\u4e00-\\u9fff]+$"
    },
    "text": {
      "type": "string",
      "maxLength": 2000
    },
    "path_text": {
      "type": "string",
      "maxLength": 512
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    },
    "failure_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "闸门",
        "名称",
        "失败类型",
        "说明"
      ],
      "properties": {
        "闸门": {
          "type": "string",
          "maxLength": 32
        },
        "名称": {
          "type": "string",
          "maxLength": 128
        },
        "状态": {
          "type": "string",
          "maxLength": 32
        },
        "说明": {
          "type": "string",
          "maxLength": 2000
        },
        "失败类型": {
          "type": "string",
          "maxLength": 128
        },
        "严重级别": {
          "type": "string",
          "maxLength": 32
        },
        "候选模块": {
          "type": "string",
          "maxLength": 32
        },
        "回流验收位置": {
          "type": "string",
          "maxLength": 32
        },
        "修复方向": {
          "type": "string",
          "maxLength": 256
        },
        "证据": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "摘句"
            ],
            "properties": {
              "段落": {
                "type": [
                  "integer",
                  "null"
                ]
              },
              "摘句": {
                "type": "string",
                "maxLength": 512
              }
            }
          }
        }
      }
    }
  }
}
